<launch>
    <arg name="config" default="$(find-pkg-share twil_bringup)/config/joint_velocity_controller.yaml"/>

    <include file="$(find-pkg-share twil_bringup)/launch/gazebo.launch.xml">
        <arg name="controller" value="joint_velocity_controller"/>
        <arg name="pause" value="false"/>
        <arg name="config" value="$(find-pkg-share t1)/config/joint_velocity_controller.yaml"/>
    </include>

    <node name="controlador" pkg="t1" exec="controlador" />

    <node pkg="tf2_ros" exec="static_transform_publisher" name="twil_origin_publisher" args="--frame-id map --child-frame-id twil_origin" />

    <node name="rviz" pkg="rviz2" exec="rviz2" args="-d $(find-pkg-share t1)/config/display.rviz">
		<param name="use_sim_time" value='$(var use_sim_time)'/>
	</node>

    <node name="odometry_publisher" pkg="arc_odometry" exec="odometry_publisher" args="--ros-args --params-file $(find-pkg-share t1)/config/odometry_config.yaml" />
</launch>
